  mFont: {fileID: 0}
  mText: "\uD558\uB298\uC5D0 \uACC4\uC2E0 \uC6B0\uB9AC \uC544\uBC84\uC9C0,\r\n\uC544\uBC84\uC9C0\uC758
    \uC774\uB984\uC744 \uAC70\uB8E9\uD558\uAC8C \uD558\uC2DC\uBA70\r\n\uC544\uBC84\uC9C0\uC758
    \uB098\uB77C\uAC00 \uC624\uAC8C \uD558\uC2DC\uBA70,\r\n\uC544\uBC84\uC9C0\uC758
    \uB73B\uC774 \uD558\uB298\uC5D0\uC11C\uC640 \uAC19\uC774 \uB545\uC5D0\uC11C\uB3C4
    \uC774\uB8E8\uC5B4\uC9C0\uAC8C \uD558\uC18C\uC11C.\r\n\uC624\uB298 \uC6B0\uB9AC\uC5D0\uAC8C
