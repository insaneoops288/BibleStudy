  mTrueTypeFont: {fileID: 12800000, guid: 0763f3174ee8db94fb5a3ef21a04331e, type: 3}
  mFont: {fileID: 0}
  mText: "-\uD558\uB098\uB2D8\uACFC\uC758 \uAD00\uACC4\uC5D0 \uB300\uD55C \uACC4\uBA85-\r\n\uCCAB\uC9F8:
    \uD558\uB098\uB2D8 \uC678\uC5D0 \uB2E4\uB978 \uC2E0\uC744 \uB450\uC9C0 \uB9D0\uC544\uC57C
    \uD569\uB2C8\uB2E4.\r\n\uB458\uC9F8: \uC6B0\uC0C1\uC744 \uB9CC\uB4E4\uAC70\uB098
    \uC12C\uAE30\uC9C0 \uB9D0\uC544\uC57C \uD569\uB2C8\uB2E4.\r\n\uC14B\uC9F8: \uD558\uB098\uB2D8\uC758
    \uC774\uB984\uC744 \uD568\uBD80\uB85C \uBD80\uB974\uC9C0 \uB9D0\uC544\uC57C \uD569\uB2C8\uB2E4.\r\n\uB137\uC9F8:
    \uC548\uC2DD\uC77C\uC744 \uAE30\uC5B5\uD558\uC5EC \uAC70\uB8E9\uD558\uAC8C \uC9C0\uCF1C\uC57C
    \uD569\uB2C8\uB2E4.\r\n\uB2E4\uC12F\uC9F8: \uBD80\uBAA8\uB97C \uACF5\uACBD\uD574\uC57C
    \uD569\uB2C8\uB2E4. \r\n\uC778\uAC04 \uAD00\uACC4\uC5D0 \uB300\uD55C \uACC4\uBA85\r\n\uC5EC\uC12F\uC9F8:
    \uC0B4\uC778\uD558\uC9C0 \uB9D0\uC544\uC57C \uD569\uB2C8\uB2E4.\r\n\uC77C\uACF1\uC9F8:
    \uAC04\uC74C\uD558\uC9C0 \uB9D0\uC544\uC57C \uD569\uB2C8\uB2E4.\r\n\uC5EC\uB35F\uC9F8:
    \uB3C4\uB451\uC9C8\uD558\uC9C0 \uB9D0\uC544\uC57C \uD569\uB2C8\uB2E4.\r\n\uC544\uD649\uC9F8:
    \uC774\uC6C3\uC5D0 \uB300\uD574 \uAC70\uC9D3 \uC99D\uC5B8\uC744 \uD558\uC9C0
    \uB9D0\uC544\uC57C \uD569\uB2C8\uB2E4.\r\n\uC5F4\uC9F8: \uC774\uC6C3\uC758 \uC9D1,
    \uC544\uB0B4, \uC18C\uC720 \uB4F1 \uBAA8\uB4E0 \uAC83\uC744 \uD0D0\uB0B4\uC9C0
    \uB9D0\uC544\uC57C \uD569\uB2C8\uB2E4. \r\n\r\n-\uC2ED\uACC4\uBA85\uC758 \uC758\uC758-\r\n\uC608\uC218
    \uADF8\uB9AC\uC2A4\uB3C4\uB294 \uC774 \uC2ED\uACC4\uBA85\uC774 \uD558\uB098\uB2D8\uC744
    \uC0AC\uB791\uD558\uACE0 \uC774\uC6C3\uC744 \uC0AC\uB791\uD558\uB294 \uB450 \uAC00\uC9C0
    \uD070 \uACC4\uBA85\uC5D0 \uC694\uC57D\uB41C\uB2E4\uACE0 \uAC00\uB974\uCE58\uC168\uC2B5\uB2C8\uB2E4."
